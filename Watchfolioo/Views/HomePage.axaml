<UserControl
    x:Class="Watchfolioo.Views.HomePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,16,12,12" Spacing="20">

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Популярні фільми"
                    x:Name="PopularMoviesTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="MoviesRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Популярні серіали"
                    x:Name="PopularSeriesTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="SeriesRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Нові фільми 2026"
                    x:Name="NewMoviesTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="NewMoviesRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Зараз шукають"
                    x:Name="SearchingNowTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="TrendingRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Нові сезони 2026"
                    x:Name="NewSeasonsTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="NewSeasonsRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Топ бойовики"
                    x:Name="TopActionTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="ActionRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock
                    Classes="SectionTitle"
                    Text="Топ комедії"
                    x:Name="TopComedyTitle" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        Name="ComedyRow"
                        Orientation="Horizontal"
                        Spacing="10" />
                </ScrollViewer>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>