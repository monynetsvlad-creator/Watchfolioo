<Window
    Height="500"
    MinHeight="450"
    MinWidth="320"
    Title="Watchfolio"
    Width="400"
    WindowStartupLocation="CenterScreen"
    x:Class="Watchfolioo.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border
            Background="#141414"
            Grid.Row="0"
            Padding="10">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Foreground="#E50914"
                HorizontalAlignment="Center"
                Text="WATCHFOLIO" />
        </Border>

        <Grid Grid.Row="1">

            <Image Source="avares://Watchfolioo/Assets/Images/Menu.jpg" Stretch="UniformToFill" />

            <StackPanel
                HorizontalAlignment="Center"
                Margin="40"
                Spacing="15"
                VerticalAlignment="Center"
                x:Name="LoginForm">

                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="#E50914"
                    HorizontalAlignment="Center"
                    Text="Watchfolio" />

                <TextBox
                    Background="#333"
                    BorderThickness="0"
                    Foreground="White"
                    PlaceholderText="Логін"
                    x:Name="LoginUser" />

                <TextBox
                    Background="#333"
                    BorderThickness="0"
                    Foreground="White"
                    PasswordChar="*"
                    PlaceholderText="Пароль"
                    x:Name="LoginPass" />

                <TextBlock
                    Foreground="Red"
                    HorizontalAlignment="Center"
                    IsVisible="False"
                    Text="Помилка"
                    x:Name="ErrorMessage" />

                <Button
                    Background="#E50914"
                    Click="Login_OnClick"
                    Content="Увійти"
                    Foreground="White"
                    HorizontalAlignment="Center" />

                <Button
                    Background="Transparent"
                    Click="ShowRegister_OnClick"
                    Content="Зареєструватися"
                    Foreground="White"
                    HorizontalAlignment="Center" />

            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                IsVisible="False"
                Margin="40"
                Spacing="15"
                VerticalAlignment="Center"
                x:Name="RegistrationForm">

                <TextBlock
                    FontSize="24"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Text="Реєстрація" />

                <TextBox
                    Background="#333"
                    BorderThickness="0"
                    Foreground="White"
                    PlaceholderText="Логін"
                    x:Name="RegUser" />

                <TextBox
                    Background="#333"
                    BorderThickness="0"
                    Foreground="White"
                    PasswordChar="*"
                    PlaceholderText="Пароль"
                    x:Name="RegPass" />

                <TextBlock
                    Foreground="Red"
                    HorizontalAlignment="Center"
                    IsVisible="False"
                    Text="Цей логін уже зайнятий!"
                    x:Name="RegErrorMessage" />

                <Button
                    Background="#E50914"
                    Click="RegisterAccount_OnClick"
                    Content="Створити профіль"
                    Foreground="White" />

                <Button
                    Background="Transparent"
                    Click="ShowLogin_OnClick"
                    Content="Назад до входу"
                    Foreground="White"
                    HorizontalAlignment="Center" />

            </StackPanel>

        </Grid>

        <Border
            Background="#141414"
            Grid.Row="2"
            Padding="8">
            <TextBlock
                Foreground="#888"
                HorizontalAlignment="Center"
                Text="© Watchfolio" />
        </Border>

    </Grid>
</Window>